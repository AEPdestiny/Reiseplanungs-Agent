{
  "name": "travel-agent",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "shared",
    "frontend",
    "backend"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev:frontend": "npm run dev -w frontend",
    "dev:backend": "npm run build -w @travel-agent/shared && npm run start:dev -w backend",
    "typecheck": "npm run typecheck --workspaces --if-present"
  }
}
